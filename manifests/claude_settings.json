{
  "env_keys": [],
  "conditional_env_keys": {
    "figma": [
      "FIGMA_API_KEY"
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)",
      "WebFetch",
      "WebSearch",
      "mcp__puppeteer__*",
      "mcp__playwright__*",
      "mcp__figma__*",
      "mcp__claude_ai_Clinical_Trials__*",
      "mcp__atlassian-jira__*",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)"
    ],
    "additionalDirectories": [
      "~/.claude"
    ]
  },
  "effortLevel": "max",
  "extraKnownMarketplaces": {
    "hartbrook-plugins": {
      "source": {
        "source": "github",
        "repo": "HartBrook/lookagain"
      }
    }
  },
  "enabledPlugins": {
    "look@hartbrook-plugins": true
  },
  "hooks": {
    "Stop": [
      { "script": "notify-done.sh" }
    ]
  }
}
