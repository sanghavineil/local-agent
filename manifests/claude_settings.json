{
  "env_keys": [
    "FIGMA_API_KEY"
  ],
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)",
      "WebFetch",
      "WebSearch",
      "mcp__puppeteer__*",
      "mcp__playwright__*",
      "mcp__figma__*",
      "mcp__claude_ai_Clinical_Trials__*",
      "mcp__atlassian-jira__*",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)"
    ],
    "additionalDirectories": [
      "~/.claude"
    ]
  },
  "effortLevel": "max"
}
